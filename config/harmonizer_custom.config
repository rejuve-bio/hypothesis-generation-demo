// Custom Nextflow config for harmonizer to use separate Python environment
// This overrides the default config without modifying the cloned repo

process {
    // Use separate Python environment for harmonizer scripts (avoids pydantic conflicts)
    beforeScript = 'export PATH="/opt/harmonizer-venv/bin:$PATH"'

    // Global defaults - prevent any single process from grabbing all RAM
    memory = '30 GB'
    cpus   = 2

    // map_to_build is the heaviest step (loads all 22 chr parquet files)
    withName: 'map_to_build' {
        memory = '38 GB'
        cpus   = 4
    }
}

executor {
    name   = 'local'
    cpus   = 8       // max CPUs Nextflow can use across all processes at once
    memory = '38 GB' // hard cap on all Nextflow processes combined
}

// Enable overwriting of trace files between runs
trace {
    enabled   = true
    overwrite = true
}

report {
    enabled   = true
    overwrite = true
}

timeline {
    enabled   = true
    overwrite = true
}